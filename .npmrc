# Electron's binary normally downloads from GitHub's release CDN, which is
# often slow/blocked on some networks (causing `RequestError: read ETIMEDOUT`
# during `npm install`). Pull it from the npmmirror CDN instead.
#
# Newer npm prints a harmless "Unknown project config" warning for these keys
# but still honours them. If a future npm ever ignores them, run instead:
#   ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ npm install
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
